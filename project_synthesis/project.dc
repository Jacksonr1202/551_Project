###############################################################################
# MazeRunner Synopsys Design Compiler Synthesis Script
#
# Purpose:
#   Synthesizes the MazeRunner RTL top-level design using the SAED32 LVT
#   standard-cell library. The script analyzes synthesizable SystemVerilog RTL,
#   excludes testbenches and behavioral simulation models, applies timing and
#   I/O constraints, compiles the design, flattens hierarchy for optimization,
#   fixes hold timing, generates reports, and writes the final gate-level netlist.
###############################################################################

#------------------------------------------------------------------------------
# Top-level design and RTL source directory
#------------------------------------------------------------------------------

set TOP MazeRunner
set SRC_DIR ./ProjectDir

# Clear any previously loaded designs from the Design Compiler session.
# This helps avoid stale modules or old constraints affecting the current run.
remove_design -all

#------------------------------------------------------------------------------
# Technology library setup
#------------------------------------------------------------------------------

# target_library:
#   The standard-cell library that Design Compiler is allowed to map RTL into.
#   This script uses the SAED32 low-threshold-voltage library, which generally
#   provides faster cells at the cost of higher leakage power.
set target_library [list ./saed32lvt_tt0p85v25c.db]

# link_library:
#   Libraries used to resolve references during elaboration/linking.
#   The "*" tells DC to also search designs already analyzed into memory.
#   standard.sldb provides Synopsys synthetic/DesignWare components.
set link_library [list * ./saed32lvt_tt0p85v25c.db standard.sldb]

#------------------------------------------------------------------------------
# Collect SystemVerilog source files
#------------------------------------------------------------------------------

# Grab all SystemVerilog files from the source directory.
set file_list [glob -nocomplain ${SRC_DIR}/*.sv]

# Stop immediately if no RTL files are found.
# This prevents accidentally running synthesis on an empty design.
if {[llength $file_list] == 0} {
    echo "ERROR: No .sv files found in ${SRC_DIR}"
    quit
}

#------------------------------------------------------------------------------
# Files intentionally excluded from synthesis
#------------------------------------------------------------------------------

# These files are testbenches, behavioral models, physics models, or other
# simulation-only files. They are required for RTL/post-synthesis simulation,
# but should not be mapped into standard cells as part of the MazeRunner DUT.
set non_synth {
    RunnerPhysics.sv
    RemoteComm.sv
    navigate_tb_starter.sv
    piezo_drv_tv.sv
    inert_intf_tb.sv
    cmd_proc_tb.sv
    SPI_iNEMO4.sv
    SPI_ADC128S.sv
    MazeRunner_tb.sv
    IR_Math_tb.sv
    ADC128S_FC.sv
    A2D_intf.sv
    MazeRunner_synth_regression_tb.sv
}

#------------------------------------------------------------------------------
# Analyze synthesizable RTL files
#------------------------------------------------------------------------------

foreach f $file_list {
    set base [file tail $f]

    # Automatically skip files following the common testbench naming convention.
    if {[string match "*_tb.sv" $base]} {
        echo "SKIPPING TB: $base"
        continue
    }

    # Skip explicitly listed simulation-only or non-synthesizable files.
    if {[lsearch -exact $non_synth $base] >= 0} {
        echo "SKIPPING NON-SYNTH: $base"
        continue
    }

    # Parse and analyze each synthesizable SystemVerilog source file.
    echo "ANALYZING: $base"
    analyze -format sverilog $f
}

#------------------------------------------------------------------------------
# Elaborate and link the top-level design
#------------------------------------------------------------------------------

# Build the full design hierarchy starting from the MazeRunner top module.
echo "ELABORATING: $TOP"
elaborate $TOP

# Set MazeRunner as the active design for constraints and compilation.
current_design $TOP

# Resolve instantiated module references against analyzed RTL and libraries.
link

# Run a pre-compile structural sanity check.
# Useful for catching unresolved references, width mismatches, undriven nets, etc.
check_design > check_design_precompile.txt

#------------------------------------------------------------------------------
# Timing constraints
#------------------------------------------------------------------------------

# Create the primary clock constraint.
# Period = 2.75 ns, corresponding to approximately 363.6 MHz.
# Note: waveform {0 1.25} gives a non-50% duty cycle; the setup timing budget
# is still primarily determined by the rising-edge-to-rising-edge period.
create_clock -name clk -period 2.75 -waveform {0 1.25} [get_ports clk]

# Prevent Design Compiler from modifying the clock network.
set_dont_touch_network [get_ports clk]

# Reserve timing margin for clock uncertainty such as skew/jitter.
set_clock_uncertainty 0.125 [get_clocks clk]

#------------------------------------------------------------------------------
# Input constraints
#------------------------------------------------------------------------------

# Select all primary inputs except the clock.
set prim_inputs [remove_from_collection [all_inputs] [get_ports clk]]

# Model external logic delay before signals reach this design's inputs.
set_input_delay -clock clk 0.6 $prim_inputs

# Model the strength/slew of the external driver for each input.
# NAND2X1_LVT means a 2-input NAND gate with X1 drive strength from the LVT lib.
set_driving_cell -lib_cell NAND2X1_LVT $prim_inputs

# Provide approximate switching activity for power estimation.
# Static probability = 0.5 means signals are assumed equally likely to be 0 or 1.
# Toggle rate = 0.25 means moderate switching relative to the base clock.
set_switching_activity -static_probability 0.5 -toggle_rate 0.25 -base_clock clk $prim_inputs

#------------------------------------------------------------------------------
# Design rule / transition constraints
#------------------------------------------------------------------------------

# Limit maximum signal transition/slew time.
# This may cause DC to insert stronger gates or buffers to meet slew constraints.
set_max_transition 0.125 [current_design]

#------------------------------------------------------------------------------
# Output constraints
#------------------------------------------------------------------------------

# Model external timing requirement after this design's outputs.
# The receiving logic is assumed to need 0.5 ns, reducing the output timing budget.
set_output_delay -clock clk 0.5 [all_outputs]

# Model capacitive load on all outputs.
# The numeric unit comes from the technology library; for SAED32 this is typically pF.
set_load 0.1 [all_outputs]

#------------------------------------------------------------------------------
# Interconnect estimation
#------------------------------------------------------------------------------

# Use a pre-layout wire-load model from the SAED32 LVT library.
# This estimates wire capacitance/resistance before physical place-and-route.
set_wire_load_model -name 16000 -library saed32lvt_tt0p85v25c

#------------------------------------------------------------------------------
# Initial compile before flattening
#------------------------------------------------------------------------------

# Perform the first synthesis pass with high mapping effort.
# This maps RTL into standard cells while preserving hierarchy.
compile -map_effort high

# Generate pre-flatten reports so the hierarchical version can be compared
# against the final flattened/optimized design.
report_area > report_area_preflatten.txt
report_timing -path full -delay max > report_timing_max_preflatten.txt
report_timing -path full -delay min > report_timing_min_preflatten.txt

#------------------------------------------------------------------------------
# Flatten hierarchy for cross-module optimization
#------------------------------------------------------------------------------

# Flatten the design hierarchy to allow DC to optimize across module boundaries.
# This can improve timing, but makes the final netlist harder to read/debug.
ungroup -all -flatten

# Ask DC to fix hold-time issues during the following incremental compile.
set_fix_hold [get_clocks clk]

# Re-optimize the already synthesized design after flattening.
# Incremental compile preserves much of the existing mapped structure while
# improving timing/design-rule results.
compile -map_effort high -incremental

#------------------------------------------------------------------------------
# Final reports
#------------------------------------------------------------------------------

# Final structural/design sanity check after optimization.
check_design > check_design.txt

# Final area report after flattening and incremental optimization.
report_area > report_area.txt

# Final setup timing report.
# Positive slack means setup timing is met; negative slack means a slow path failed.
report_timing -path full -delay max > report_timing_max.txt

# Final hold timing report.
# Positive slack means hold timing is met; negative slack means a short path failed.
report_timing -path full -delay min > report_timing_min.txt

# Final estimated power report based on library data and switching assumptions.
report_power > report_power.txt

#------------------------------------------------------------------------------
# Write synthesized gate-level netlist
#------------------------------------------------------------------------------

# Write the mapped Verilog netlist for post-synthesis simulation.
write -format verilog -hierarchy -output MazeRunner.vg

echo "DONE: synthesized MazeRunner with LVT and wrote MazeRunner.vg"